    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/desktop-1.jpg",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "wide",
      "label": "TJGOHub - Desktop"
    },
    {
      "src": "/screenshots/mobile-1.jpg",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "TJGOHub - Mobile"
    }
  ],
  "categories": ["productivity", "utilities"],
  "lang": "pt-BR",
  "dir": "ltr",
  "edge_side_panel": {
    "preferred_width": 400
  },
  "shortcuts": [
    {
      "name": "Dashboard",
      "short_name": "Dashboard",
