# =============================================================
# TJGOHub Frontend — Variáveis de Produção
# =============================================================

# URL do Django backend em produção
NEXT_PUBLIC_API_URL=https://api.tjgo.jus.br
DJANGO_API_URL=https://api.tjgo.jus.br

# Ambiente
NEXT_PUBLIC_ENVIRONMENT=production
NEXT_PUBLIC_DEBUG_MODE=false

# PWA
NEXT_PUBLIC_PWA_ENABLED=true

# Build
ANALYZE=false
NEXT_TELEMETRY_DISABLED=1
